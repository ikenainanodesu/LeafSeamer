{
  "name": "atem-control",
  "version": "1.1.0",
  "nodecg": {
    "compatibleRange": "^2.0.0",
    "dashboardPanels": [
      {
        "name": "atem-connection",
        "title": "ATEM Connection",
        "width": 3,
        "file": "atem-connection.html",
        "headerColor": "#525252",
        "workspace": "ATEM Control"
      },
      {
        "name": "atem-control",
        "title": "ATEM Control",
        "width": 5,
        "file": "atem-control.html",
        "headerColor": "#525252",
        "workspace": "ATEM Control"
      }
    ]
  },
  "scripts": {
    "build:extension": "vite build --config vite.config.mjs --mode extension",
    "build:dashboard": "vite build --config vite.config.mjs --mode dashboard",
    "build": "npm run build:extension && npm run build:dashboard",
    "watch:extension": "vite build --config vite.config.mjs --mode extension --watch",
    "watch": "npm run watch:extension"
  },
  "dependencies": {
    "atem-connection": "^3.3.0",
    "lucide-react": "1.23.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "nodecg": "^2.6.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
