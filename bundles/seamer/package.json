{
  "name": "seamer",
  "version": "1.0.0",
  "nodecg": {
    "compatibleRange": "^2.0.0",
    "dashboardPanels": [
      {
        "name": "seamer-panel",
        "title": "Seamer Control",
        "width": 8,
        "file": "seamer.html",
        "headerColor": "#525252",
        "workspace": "Seamer"
      }
    ]
  },
  "scripts": {
    "build:extension": "vite build --config vite.config.mjs --mode extension",
    "build:dashboard": "vite build --config vite.config.mjs --mode dashboard",
    "build": "npm run build:extension && npm run build:dashboard",
    "watch:extension": "vite build --config vite.config.mjs --mode extension --watch",
    "watch": "npm run watch:extension"
  },
  "dependencies": {
    "lucide-react": "1.23.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "nodecg": "^2.6.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  }
}
