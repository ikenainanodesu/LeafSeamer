    "ui:check": "ts-node scripts/sync-dashboard-ui.ts --check",
    "test:standalone": "powershell -ExecutionPolicy Bypass -File scripts/test-standalone-bundle.ps1",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test:ui": "npm run build && playwright test",
    "test:ui:update": "npm run build && playwright test --update-snapshots"
